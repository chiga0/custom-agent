{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@custom-agent/schema": ["packages/schema/src/index.ts"],
      "@custom-agent/schema/acp": ["packages/schema/src/acp.ts"],
      "@custom-agent/acp-server": ["apps/acp-server/src/index.ts"],
      "@custom-agent/acp-daemon": ["apps/acp-daemon/src/index.ts"],
      "@custom-agent/core": ["packages/core/src/index.ts"],
      "@custom-agent/storage": ["packages/storage/src/index.ts"],
      "@custom-agent/permissions": ["packages/permissions/src/index.ts"],
      "@custom-agent/qa-fixtures": ["packages/qa-fixtures/src/index.ts"],
      "@custom-agent/model-gateway": ["packages/model-gateway/src/index.ts"],
      "@custom-agent/model-gateway/providers/recorded": [
        "packages/model-gateway/src/providers/recorded.ts"
      ]
    }
  }
}
